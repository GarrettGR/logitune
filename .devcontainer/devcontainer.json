{
    "name": "Logitune Dev",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "USERNAME": "${localEnv:USER}"
        }
    },

    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-vscode.cmake-tools",
                "twxs.cmake",
                "vscode-icons-team.vscode-icons",
                "theqtcompany.qt",
                "theqtcompany.qt-qml",
                "theqtcompany.qt-cpp",
                "ms-vscode.cpp-devtools"
            ],
            "settings": {
                "cmake.buildDirectory": "${workspaceFolder}/build",
                "cmake.generator": "Ninja",
                "cmake.configureArgs": [
                    "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                    "-DCMAKE_BUILD_TYPE=Debug"
                ],
                "clangd.path": "/usr/bin/clangd",
                "clangd.arguments": [
                    "--compile-commands-dir=${workspaceFolder}/build",
                    "--header-insertion=iwyu",
                    "--background-index"
                ],
                "C_Cpp.intelliSenseEngine": "disabled",
                "workbench.iconTheme": "vscode-icons",
                "qt-qml.qmlls.enabled": true,
                "qt-qml.qmlls.verboseOutput": false,
                "terminal.integrated.defaultProfile.linux": "fish",
                "terminal.integrated.fontFamily": "MesloLGS Nerd Font Mono",
                "editor.tabSize": 4,
                "editor.insertSpaces": true,
                "files.associations": {
                    "*.qml": "qml",
                    "CMakeLists.txt": "cmake"
                }
            }
        }
    },

    "runArgs": ["--privileged", "--hostname", "logitune-dev"],
    "remoteUser": "${localEnv:USER:ubuntu}",
    "updateRemoteUserUID": true,

    "postCreateCommand": "make setup-hooks && sudo rm -rf build && cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build build -j$(nproc)",
    "postStartCommand": "make help && echo '' && echo '✅ Logitune dev environment ready. Type: make test-all'"
}
